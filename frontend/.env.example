# Backend API URL (default: http://localhost:3001/api)
# Change this if your backend runs on a different host or port.
VITE_API_URL=http://localhost:3001/api

# ── Supabase Realtime (optional — enables live push notifications) ──────────
# Get both values from: Supabase Dashboard → Settings → API
# VITE_SUPABASE_URL is the same as SUPABASE_URL in backend/.env
# VITE_SUPABASE_ANON_KEY is the *anon/public* key (safe to expose in browser)
#
# RLS requirement: The anon role needs SELECT on `sales` and `products` tables
# filtered by shop_id.  In Supabase Dashboard → Authentication → Policies add:
#   CREATE POLICY "anon can read own shop sales" ON sales FOR SELECT TO anon
#     USING (true);   -- Supabase Realtime applies the filter server-side.
#
# JWT requirement: If your backend uses a custom JWT_SECRET, set it in:
#   Supabase Dashboard → Settings → Auth → JWT Settings → Custom JWT secret
# so supabase.realtime.setAuth(token) is accepted.
#
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
